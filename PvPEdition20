                        Opt.AutoButtonColor = false; Opt.Parent = List 
                        Corner(Opt, 3) 
                        Opt.MouseEnter:Connect(function() Tween(Opt, {BackgroundTransparency = 0.3}, 0.1) end) 
                        Opt.MouseLeave:Connect(function() Tween(Opt, {BackgroundTransparency = (val==Drp.Value) and 0.4 or 1}, 0.1) end) 
                        Opt.MouseButton1Click:Connect(function() 
                            PlaySound(AuraUI.Sounds.Click, 0.22, 1.15) 
                            SetValue(val) 
                            open = false 
                            Tween(Wrap, {Size = UDim2.new(1, 0, 0, 36)}, 0.25) 
                            ArrowIco.Text = "▼" 
                        end) 
                    end 
                    List.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y) 
