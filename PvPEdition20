    -- ── Internal: switch to a tab by name ───────────────────────────────────── 
    local function SwitchTab(name) 
        if WD.CurrentTab == name then return end 
        WD.CurrentTab = name 
        for tName, td in pairs(WD.Tabs) do 
            local active = (tName == name) 
            td._Page.Visible = active 
            if active then 
                Tween(td._Btn, {BackgroundColor3 = AuraUI.Theme.TabBtnActive, BackgroundTransparency = 0}, 0.12) 
                Tween(td._Label, {TextColor3 = AuraUI.Theme.Text}, 0.12) 
                Tween(td._UnderLine, {BackgroundTransparency = 0}, 0.12) 
                Reg(td._Label, "TextColor3", "Text") 
            else 
                Tween(td._Btn, {BackgroundTransparency = 1}, 0.12) 
                Tween(td._Label, {TextColor3 = AuraUI.Theme.TextMuted}, 0.12) 
                Tween(td._UnderLine, {BackgroundTransparency = 1}, 0.12) 
                Reg(td._Label, "TextColor3", "TextMuted") 
            end 
        end 
    end 
 
