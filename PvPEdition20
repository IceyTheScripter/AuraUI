                end 

                local function Build() 
                    for _, c in ipairs(List:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end 
                    for _, val in ipairs(Drp.Values) do 
                        local Opt = Instance.new("TextButton") 
                        Opt.Size = UDim2.new(1, -4, 0, 22) 
                        Opt.BackgroundColor3 = (val == Drp.Value) and AuraUI.Theme.Primary or AuraUI.Theme.Element 
                        Opt.BackgroundTransparency = (val == Drp.Value) and 0.4 or 1 
                        Opt.Text = "  " .. val 
                        Opt.TextColor3 = (val == Drp.Value) and AuraUI.Theme.Primary or AuraUI.Theme.Text 
                        Opt.Font = Enum.Font.Gotham; Opt.TextSize = 11 
