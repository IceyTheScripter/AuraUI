    mini.InputChanged:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseMovement then mbInp = inp end end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp == mbInp and mbDrag then local d = inp.Position - mbStart; mbDist = d.Magnitude; mini.Position = UDim2.new(mbPos.X.Scale, mbPos.X.Offset + d.X, mbPos.Y.Scale, mbPos.Y.Offset + d.Y) end
