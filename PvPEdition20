                        Tween(Wrap, {Size = UDim2.new(1, 0, 0, h)}, 0.3) 
                        ArrowIco.Text = "▲" 
                        focused = true 
                    else 
                        open = false 
                        Tween(Wrap, {Size = UDim2.new(1, 0, 0, 36)}, 0.25) 
                        ArrowIco.Text = "▼" 
                        focused = false 
                    end 
                end) 
 
                local function Cycle(dir) 
                    local idx = 1 
                    for i, v in ipairs(Drp.Values) do if v == Drp.Value then idx = i break end end 
                    local nIdx = ((idx + dir - 1) % #Drp.Values) + 1 
                    SetValue(Drp.Values[nIdx]) 
                    PlaySound(AuraUI.Sounds.Click, 0.2, 1.1) 
                end 


                LeftArrow.MouseButton1Click:Connect(function() Cycle(-1) end) 
                RightArrow.MouseButton1Click:Connect(function() Cycle(1) end) 

                LeftArrow.MouseEnter:Connect(function() Tween(LeftArrow, {TextColor3 = AuraUI.Theme.Primary}, 0.1) end) 
                LeftArrow.MouseLeave:Connect(function() Tween(LeftArrow, {TextColor3 = AuraUI.Theme.TextMuted}, 0.1) end) 
                RightArrow.MouseEnter:Connect(function() Tween(RightArrow, {TextColor3 = AuraUI.Theme.Primary}, 0.1) end) 
                RightArrow.MouseLeave:Connect(function() Tween(RightArrow, {TextColor3 = AuraUI.Theme.TextMuted}, 0.1) end) 

                BtnF.MouseEnter:Connect(function() focused = true end) 
                BtnF.MouseLeave:Connect(function() if not open then focused = false end end)

                UserInputService.InputBegan:Connect(function(inp, gpe) 
                    if not focused or gpe then return end 
                    if inp.KeyCode == Enum.KeyCode.Left then Cycle(-1) 
                    elseif inp.KeyCode == Enum.KeyCode.Right then Cycle(1) 
                    elseif inp.KeyCode == Enum.KeyCode.Escape and open then 
                        open = false; Tween(Wrap, {Size = UDim2.new(1, 0, 0, 36)}, 0.2) 
                        ArrowIco.Text = "▼" 
                    end 
                end) 

                function Drp:Refresh(newVals) 
                    Drp.Values = newVals or Drp.Values 
                    if not table.find(Drp.Values, Drp.Value) then SetValue(Drp.Values[1]) end 
                    if open then Build() end 
                end 

                function Drp:Set(v) SetValue(v); if open then Build() end end 

                AuraUI.Options[id] = Drp 
                return Drp 
            end 
 
