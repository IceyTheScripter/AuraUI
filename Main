    glow.Name = "Glow"; glow.BackgroundTransparency = 1; glow.Position = UDim2.new(0, -15, 0, -15); glow.Size = UDim2.new(1, 30, 1, 30)
    glow.ZIndex = 0; glow.Image = "rbxassetid://5028857084"; glow.ImageColor3 = currentTheme.primary; glow.ImageTransparency = 0.5; glow.ScaleType = Enum.ScaleType.Slice; glow.SliceCenter = Rect.new(24, 24, 276, 276); glow.Parent = mf
