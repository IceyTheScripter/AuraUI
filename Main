        btn.MouseButton1Click:Connect(function() playSound(Sounds.click, 0.4, 1); Window:SelectTab(Tab.Name) end)
        btn.MouseEnter:Connect(function() if Window.CurrentTab ~= Tab.Name then playSound(Sounds.hover, 0.2, 1.1); tw(btn, {BackgroundTransparency = 0.85, BackgroundColor3 = currentTheme.topbar}, 0.15) end end)
        btn.MouseLeave:Connect(function() if Window.CurrentTab ~= Tab.Name then tw(btn, {BackgroundTransparency = 1}, 0.15) end end)

        Window.Tabs[Tab.Name] = {Btn = btn, Str = str, Frame = sFrame}

        local function baseObj(h)
            local f = Instance.new("Frame"); f.Size = UDim2.new(1, 0, 0, h); f.BackgroundColor3 = currentTheme.topbar; f.BackgroundTransparency = 0.5; f.Parent = sFrame
            local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 6); c.Parent = f
