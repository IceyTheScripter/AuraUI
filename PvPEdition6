                Nub.Parent = Fill 
                Corner(Nub, 5) 
 
                local Trig = Instance.new("TextButton") 
                Trig.Size = UDim2.new(1, 0, 1, 14) 
                Trig.Position = UDim2.new(0, 0, 0, -7) 
                Trig.BackgroundTransparency = 1 
                Trig.Text = "" 
                Trig.Parent = TBg 
 
                local drag = false 
                local function upd(inp) 
                    local pct = math.clamp((inp.Position.X - TBg.AbsolutePosition.X) / TBg.AbsoluteSize.X, 0, 1) 
                    local raw = opts.Min + pct * (opts.Max - opts.Min) 
                    if opts.Rounding then raw = math.floor(raw/opts.Rounding+0.5)*opts.Rounding 
                    else raw = math.floor(raw+0.5) end 
                    raw = math.clamp(raw, opts.Min, opts.Max) 
                    Sld.Value = raw; ValLbl.Text = tostring(raw) 
                    Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05) 
                    if opts.Callback then opts.Callback(raw) end 
                end 
 
                Trig.InputBegan:Connect(function(i) 
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; upd(i) end 
                end) 
                UserInputService.InputEnded:Connect(function(i) 
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end 
                end) 
                UserInputService.InputChanged:Connect(function(i) 
                    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then upd(i) end 
                end) 
 
                function Sld:Set(v) 
                    Sld.Value = math.clamp(v, opts.Min, opts.Max) 
                    ValLbl.Text = tostring(Sld.Value) 
                    Tween(Fill, {Size = UDim2.new((Sld.Value-opts.Min)/(opts.Max-opts.Min), 0, 1, 0)}, 0.15) 
                    if opts.Callback then opts.Callback(Sld.Value) end
                end 
 
                AuraUI.Options[id] = Sld 
                return Sld 
            end 
 
