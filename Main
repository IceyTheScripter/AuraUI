AuraUI.CurrentThemeName = "Glass Dark"
AuraUI.Theme = AuraUI.Themes[AuraUI.CurrentThemeName]
AuraUI.Options = {}
AuraUI.Toggled = true
AuraUI.ThemeObjects = {}

-- Utility Functions
local function CreateTween(instance, properties, duration, style, direction)
    local tweenInfo = TweenInfo.new(duration or 0.2, style or Enum.EasingStyle.Quart, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function MakeDraggable(topbar, main)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            CreateTween(main, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.1)
        end
    end)
end

local function CreateRipple(button)
    local ripple = Instance.new("Frame")
    ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    ripple.BackgroundTransparency = 0.6
    ripple.BorderSizePixel = 0
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ripple
    
    ripple.Parent = button
    
    local mouseLocal = Vector2.new(Mouse.X - button.AbsolutePosition.X, Mouse.Y - button.AbsolutePosition.Y)
    ripple.Position = UDim2.new(0, mouseLocal.X, 0, mouseLocal.Y)
    ripple.Size = UDim2.new(0, 0, 0, 0)
    
    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.5
    CreateTween(ripple, {Size = UDim2.new(0, maxSize, 0, maxSize), BackgroundTransparency = 1}, 0.5)
    
    task.delay(0.5, function() ripple:Destroy() end)
end

local function UpdateTheme()
    local t = AuraUI.Themes[AuraUI.CurrentThemeName]
    AuraUI.Theme = t
    for obj, data in pairs(AuraUI.ThemeObjects) do
        if obj and obj.Parent then
            CreateTween(obj, {[data.Prop] = t[data.Key]}, 0.3)
        else
            AuraUI.ThemeObjects[obj] = nil
        end
    end
end

local function Reg(obj, prop, key)
    AuraUI.ThemeObjects[obj] = {Prop = prop, Key = key}
    obj[prop] = AuraUI.Theme[key]
end

-- Core Window
function AuraUI:CreateWindow(config)
    local WindowData = {
        Tabs = {},
        CurrentTab = nil,
        Keybind = config.Keybind or Enum.KeyCode.RightControl
    }

    local gui = Instance.new("ScreenGui")
    gui.Name = "AuraPremium"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    if syn and syn.protect_gui then syn.protect_gui(gui) end
    gui.Parent = (gethui and gethui()) or CoreGui

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 650, 0, 420)
    MainFrame.Position = UDim2.new(0.5, -325, 0.5, -210)
    MainFrame.BackgroundTransparency = 0.05
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = false
    MainFrame.Parent = gui
    Reg(MainFrame, "BackgroundColor3", "Background")

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Thickness = 1.5
    MainStroke.Transparency = 0.5
    MainStroke.Parent = MainFrame
    Reg(MainStroke, "Color", "Primary")

    -- Inner drop shadow to give 3D depth
    local Shadow = Instance.new("ImageLabel")
    Shadow.Size = UDim2.new(1, 40, 1, 40)
    Shadow.Position = UDim2.new(0, -20, 0, -20)
    Shadow.BackgroundTransparency = 1
    Shadow.Image = "rbxassetid://1316045217"
    Shadow.ImageTransparency = 0.4
    Shadow.ZIndex = -1
    Shadow.Parent = MainFrame

    -- Layout split: Sidebar (Left) & Content (Right)
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 160, 1, 0)
    Sidebar.BackgroundTransparency = 0.5
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame
    Reg(Sidebar, "BackgroundColor3", "Sidebar")

    local SidebarCorner = Instance.new("UICorner")
    SidebarCorner.CornerRadius = UDim.new(0, 8)
    SidebarCorner.Parent = Sidebar

    local SidebarDivider = Instance.new("Frame")
    SidebarDivider.Size = UDim2.new(0, 1, 1, 0)
    SidebarDivider.Position = UDim2.new(1, 0, 0, 0)
    SidebarDivider.BorderSizePixel = 0
    SidebarDivider.Parent = Sidebar
    Reg(SidebarDivider, "BackgroundColor3", "Border")

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -161, 1, 0)
    ContentContainer.Position = UDim2.new(0, 161, 0, 0)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    -- Topbar handling (Draggable invisible overlay for the whole window)
    local DragOverlay = Instance.new("TextButton")
    DragOverlay.Size = UDim2.new(1, 0, 0, 40)
    DragOverlay.BackgroundTransparency = 1
    DragOverlay.Text = ""
    DragOverlay.Parent = MainFrame
    MakeDraggable(DragOverlay, MainFrame)

    -- Window Title in Sidebar
    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -20, 0, 40)
    TitleLabel.Position = UDim2.new(0, 20, 0, 10)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = config.Title or "Aura"
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 20
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = Sidebar
    Reg(TitleLabel, "TextColor3", "Text")

    local SubTitleLabel = Instance.new("TextLabel")
    SubTitleLabel.Size = UDim2.new(1, -20, 0, 16)
    SubTitleLabel.Position = UDim2.new(0, 20, 0, 32)
    SubTitleLabel.BackgroundTransparency = 1
    SubTitleLabel.Text = config.SubTitle or "Premium Hub"
    SubTitleLabel.Font = Enum.Font.Gotham
    SubTitleLabel.TextSize = 12
    SubTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    SubTitleLabel.Parent = Sidebar
    Reg(SubTitleLabel, "TextColor3", "Primary")

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(1, 0, 1, -70)
    TabContainer.Position = UDim2.new(0, 0, 0, 70)
    TabContainer.BackgroundTransparency = 1
    TabContainer.BorderSizePixel = 0
    TabContainer.ScrollBarThickness = 0
    TabContainer.Parent = Sidebar

    local TabList = Instance.new("UIListLayout")
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Padding = UDim.new(0, 4)
    TabList.Parent = TabContainer

    -- Handle Keybind Toggle
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == WindowData.Keybind then
            AuraUI.Toggled = not AuraUI.Toggled
            if AuraUI.Toggled then
                MainFrame.Visible = true
                CreateTween(MainFrame, {Size = UDim2.new(0, 650, 0, 420), BackgroundTransparency = 0.05}, 0.35, Enum.EasingStyle.Back)
                CreateTween(MainStroke, {Transparency = 0.5}, 0.3)
                for _, obj in pairs(MainFrame:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                        CreateTween(obj, {TextTransparency = 0}, 0.2)
                    elseif obj:IsA("ImageLabel") then
                        CreateTween(obj, {ImageTransparency = obj.Name == "Shadow" and 0.4 or 0}, 0.2)
                    elseif obj:IsA("Frame") and obj.Name ~= "MainFrame" then
                        CreateTween(obj, {BackgroundTransparency = obj:GetAttribute("TargetTransparency") or 0}, 0.2)
                    end
                end
            else
                CreateTween(MainFrame, {Size = UDim2.new(0, 600, 0, 380), BackgroundTransparency = 1}, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In)
                CreateTween(MainStroke, {Transparency = 1}, 0.3)
                for _, obj in pairs(MainFrame:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                        CreateTween(obj, {TextTransparency = 1}, 0.2)
                    elseif obj:IsA("ImageLabel") then
                        CreateTween(obj, {ImageTransparency = 1}, 0.2)
                    elseif obj:IsA("Frame") and obj.Name ~= "MainFrame" then
                        if not obj:GetAttribute("TargetTransparency") then obj:SetAttribute("TargetTransparency", obj.BackgroundTransparency) end
                        CreateTween(obj, {BackgroundTransparency = 1}, 0.2)
                    end
                end
                task.wait(0.35)
                MainFrame.Visible = false
            end
        end
    end)

    function WindowData:AddTab(name, iconId)
        local TabData = {Name = name}
        
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, -20, 0, 34)
        TabBtn.Position = UDim2.new(0, 10, 0, 0)
        TabBtn.BackgroundColor3 = AuraUI.Theme.Element
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = ""
        TabBtn.AutoButtonColor = false
        TabBtn.Parent = TabContainer

        local TabBtnCorner = Instance.new("UICorner")
        TabBtnCorner.CornerRadius = UDim.new(0, 6)
        TabBtnCorner.Parent = TabBtn

        local Icon = Instance.new("ImageLabel")
        Icon.Size = UDim2.new(0, 18, 0, 18)
        Icon.Position = UDim2.new(0, 12, 0.5, -9)
        Icon.BackgroundTransparency = 1
        Icon.Image = iconId or "rbxassetid://15222045585"
        Icon.ImageColor3 = AuraUI.Theme.TextMuted
        Icon.Parent = TabBtn
        Reg(Icon, "ImageColor3", "TextMuted")

        local Title = Instance.new("TextLabel")
        Title.Size = UDim2.new(1, -40, 1, 0)
        Title.Position = UDim2.new(0, 38, 0, 0)
        Title.BackgroundTransparency = 1
        Title.Text = name
        Title.Font = Enum.Font.GothamMedium
        Title.TextSize = 13
        Title.TextXAlignment = Enum.TextXAlignment.Left
        Title.Parent = TabBtn
        Reg(Title, "TextColor3", "TextMuted")

        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 3, 0, 0)
        Indicator.Position = UDim2.new(0, 0, 0.5, 0)
        Indicator.AnchorPoint = Vector2.new(0, 0.5)
        Indicator.BorderSizePixel = 0
        Indicator.Parent = TabBtn
        Reg(Indicator, "BackgroundColor3", "Primary")

        local IndicatorCorner = Instance.new("UICorner")
        IndicatorCorner.CornerRadius = UDim.new(1, 0)
        IndicatorCorner.Parent = Indicator

        local Page = Instance.new("ScrollingFrame")
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.BorderSizePixel = 0
        Page.ScrollBarThickness = 2
        Page.Visible = false
        Page.Parent = ContentContainer
        Reg(Page, "ScrollBarImageColor3", "Border")

        local PagePadding = Instance.new("UIPadding")
        PagePadding.PaddingTop = UDim.new(0, 16)
        PagePadding.PaddingBottom = UDim.new(0, 16)
        PagePadding.PaddingLeft = UDim.new(0, 16)
        PagePadding.PaddingRight = UDim.new(0, 16)
        PagePadding.Parent = Page

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 12)
        PageLayout.Parent = Page

        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 32)
        end)

        WindowData.Tabs[name] = {Btn = TabBtn, Title = Title, Icon = Icon, Indicator = Indicator, Page = Page}

        TabBtn.MouseButton1Click:Connect(function()
            for tName, data in pairs(WindowData.Tabs) do
                if tName == name then
                    WindowData.CurrentTab = name
                    data.Page.Visible = true
                    CreateTween(data.Page, {CanvasPosition = Vector2.new(0, 0)}, 0.3)
                    CreateTween(data.Btn, {BackgroundTransparency = 0.5}, 0.2)
                    CreateTween(data.Title, {TextColor3 = AuraUI.Theme.Text}, 0.2)
                    CreateTween(data.Icon, {ImageColor3 = AuraUI.Theme.Primary}, 0.2)
                    CreateTween(data.Indicator, {Size = UDim2.new(0, 3, 0, 18)}, 0.3, Enum.EasingStyle.Back)
                    Reg(data.Title, "TextColor3", "Text")
                else
                    data.Page.Visible = false
                    CreateTween(data.Btn, {BackgroundTransparency = 1}, 0.2)
                    CreateTween(data.Title, {TextColor3 = AuraUI.Theme.TextMuted}, 0.2)
                    CreateTween(data.Icon, {ImageColor3 = AuraUI.Theme.TextMuted}, 0.2)
                    CreateTween(data.Indicator, {Size = UDim2.new(0, 3, 0, 0)}, 0.2)
                    Reg(data.Title, "TextColor3", "TextMuted")
                end
            end
        end)
        
        if not WindowData.CurrentTab then
            WindowData.CurrentTab = name
            Page.Visible = true
            TabBtn.BackgroundTransparency = 0.5
            Title.TextColor3 = AuraUI.Theme.Text
            Icon.ImageColor3 = AuraUI.Theme.Primary
            Indicator.Size = UDim2.new(0, 3, 0, 18)
            Reg(Title, "TextColor3", "Text")
        end

        function TabData:AddSection(secName)
            local SectionData = {}
            local SecFrame = Instance.new("Frame")
            SecFrame.Size = UDim2.new(1, 0, 0, 0)
            SecFrame.BackgroundColor3 = AuraUI.Theme.Card
            SecFrame.BackgroundTransparency = 0.4
            SecFrame.BorderSizePixel = 0
            SecFrame.ClipsDescendants = true
            SecFrame.Parent = Page
            Reg(SecFrame, "BackgroundColor3", "Card")

            local SecCorner = Instance.new("UICorner")
            SecCorner.CornerRadius = UDim.new(0, 6)
            SecCorner.Parent = SecFrame

            local SecStroke = Instance.new("UIStroke")
            SecStroke.Color = AuraUI.Theme.Border
            SecStroke.Thickness = 1
            SecStroke.Parent = SecFrame
            Reg(SecStroke, "Color", "Border")

            local SecTitle = Instance.new("TextLabel")
            SecTitle.Size = UDim2.new(1, -24, 0, 32)
            SecTitle.Position = UDim2.new(0, 12, 0, 0)
            SecTitle.BackgroundTransparency = 1
            SecTitle.Text = secName
            SecTitle.Font = Enum.Font.GothamBold
            SecTitle.TextColor3 = AuraUI.Theme.Text
            SecTitle.TextSize = 13
            SecTitle.TextXAlignment = Enum.TextXAlignment.Left
            SecTitle.Parent = SecFrame
            Reg(SecTitle, "TextColor3", "Text")

            local SecContainer = Instance.new("Frame")
            SecContainer.Size = UDim2.new(1, -24, 0, 0)
            SecContainer.Position = UDim2.new(0, 12, 0, 32)
            SecContainer.BackgroundTransparency = 1
            SecContainer.Parent = SecFrame

            local SecLayout = Instance.new("UIListLayout")
            SecLayout.SortOrder = Enum.SortOrder.LayoutOrder
            SecLayout.Padding = UDim.new(0, 8)
            SecLayout.Parent = SecContainer

            SecLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                SecContainer.Size = UDim2.new(1, -24, 0, SecLayout.AbsoluteContentSize.Y)
                SecFrame.Size = UDim2.new(1, 0, 0, SecLayout.AbsoluteContentSize.Y + 44)
            end)

            function SectionData:AddToggle(id, opts)
                local T = {Value = opts.Default or false}
                
                local f = Instance.new("TextButton")
                f.Size = UDim2.new(1, 0, 0, 32)
                f.BackgroundTransparency = 1
                f.Text = ""
                f.Parent = SecContainer

                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, -50, 1, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text = opts.Title
                lbl.TextColor3 = AuraUI.Theme.TextMuted
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 13
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = f
                Reg(lbl, "TextColor3", "TextMuted")

                local track = Instance.new("Frame")
                track.Size = UDim2.new(0, 36, 0, 18)
                track.Position = UDim2.new(1, -36, 0.5, -9)
                track.BackgroundColor3 = AuraUI.Theme.Element
                track.BorderSizePixel = 0
                track.Parent = f
                Reg(track, "BackgroundColor3", "Element")
                
                local trackCorner = Instance.new("UICorner")
                trackCorner.CornerRadius = UDim.new(1, 0)
                trackCorner.Parent = track
                
                local tStroke = Instance.new("UIStroke")
                tStroke.Color = AuraUI.Theme.Border
                tStroke.Parent = track
                Reg(tStroke, "Color", "Border")

                local thumb = Instance.new("Frame")
                thumb.Size = UDim2.new(0, 14, 0, 14)
                thumb.Position = UDim2.new(0, 2, 0.5, -7)
                thumb.BackgroundColor3 = AuraUI.Theme.TextMuted
                thumb.BorderSizePixel = 0
                thumb.Parent = track
                
                local thumbCorner = Instance.new("UICorner")
                thumbCorner.CornerRadius = UDim.new(1, 0)
                thumbCorner.Parent = thumb

                local function updateAnim()
                    if T.Value then
                        CreateTween(track, {BackgroundColor3 = AuraUI.Theme.Primary}, 0.25)
                        CreateTween(thumb, {Position = UDim2.new(1, -16, 0.5, -7), BackgroundColor3 = Color3.new(1,1,1)}, 0.25, Enum.EasingStyle.Back)
                        CreateTween(lbl, {TextColor3 = AuraUI.Theme.Text}, 0.2)
                    else
                        CreateTween(track, {BackgroundColor3 = AuraUI.Theme.Element}, 0.25)
                        CreateTween(thumb, {Position = UDim2.new(0, 2, 0.5, -7), BackgroundColor3 = AuraUI.Theme.TextMuted}, 0.25)
                        CreateTween(lbl, {TextColor3 = AuraUI.Theme.TextMuted}, 0.2)
                    end
                end

                f.MouseButton1Click:Connect(function()
                    T.Value = not T.Value
                    updateAnim()
                    if opts.Callback then opts.Callback(T.Value) end
                end)
                f.MouseEnter:Connect(function() CreateTween(tStroke, {Color = AuraUI.Theme.TextMuted}, 0.2) end)
                f.MouseLeave:Connect(function() CreateTween(tStroke, {Color = AuraUI.Theme.Border}, 0.2) end)

                updateAnim()
                AuraUI.Options[id] = T
                return T
            end

            function SectionData:AddButton(opts)
                local f = Instance.new("TextButton")
                f.Size = UDim2.new(1, 0, 0, 36)
                f.BackgroundColor3 = AuraUI.Theme.Element
                f.BackgroundTransparency = 0.5
                f.Text = ""
                f.AutoButtonColor = false
                f.Parent = SecContainer
                Reg(f, "BackgroundColor3", "Element")

                local tc = Instance.new("UICorner")
                tc.CornerRadius = UDim.new(0, 6)
                tc.Parent = f
                
                local stroke = Instance.new("UIStroke")
                stroke.Color = AuraUI.Theme.Border
                stroke.Parent = f
                Reg(stroke, "Color", "Border")

                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, -24, 1, 0)
                lbl.Position = UDim2.new(0, 12, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.Text = opts.Title
                lbl.TextColor3 = AuraUI.Theme.Text
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 13
                lbl.TextXAlignment = Enum.TextXAlignment.Center
                lbl.Parent = f
                Reg(lbl, "TextColor3", "Text")

                f.MouseEnter:Connect(function()
                    CreateTween(f, {BackgroundTransparency = 0.1}, 0.15)
                    CreateTween(stroke, {Color = AuraUI.Theme.Primary}, 0.15)
                end)
                f.MouseLeave:Connect(function()
                    CreateTween(f, {BackgroundTransparency = 0.5}, 0.25)
                    CreateTween(stroke, {Color = AuraUI.Theme.Border}, 0.25)
                end)
                f.MouseButton1Click:Connect(function()
                    CreateRipple(f)
                    if opts.Callback then opts.Callback() end
                end)
            end

            function SectionData:AddSlider(id, opts)
                local S = {Value = opts.Default or opts.Min}
                
                local f = Instance.new("Frame")
                f.Size = UDim2.new(1, 0, 0, 48)
                f.BackgroundTransparency = 1
                f.Parent = SecContainer

                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, 0, 0, 16)
                lbl.BackgroundTransparency = 1
                lbl.Text = opts.Title
                lbl.TextColor3 = AuraUI.Theme.TextMuted
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 13
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Parent = f
                Reg(lbl, "TextColor3", "TextMuted")
                
                local valLbl = Instance.new("TextLabel")
                valLbl.Size = UDim2.new(1, 0, 0, 16)
                valLbl.BackgroundTransparency = 1
                valLbl.Text = tostring(S.Value)
                valLbl.TextColor3 = AuraUI.Theme.Text
                valLbl.Font = Enum.Font.GothamBold
                valLbl.TextSize = 13
                valLbl.TextXAlignment = Enum.TextXAlignment.Right
                valLbl.Parent = f
                Reg(valLbl, "TextColor3", "Text")

                local trackBack = Instance.new("Frame")
                trackBack.Size = UDim2.new(1, 0, 0, 6)
                trackBack.Position = UDim2.new(0, 0, 0, 32)
                trackBack.BackgroundColor3 = AuraUI.Theme.Element
                trackBack.BorderSizePixel = 0
                trackBack.Parent = f
                Reg(trackBack, "BackgroundColor3", "Element")
                
                local trackingC = Instance.new("UICorner")
                trackingC.CornerRadius = UDim.new(1, 0)
                trackingC.Parent = trackBack

                local fill = Instance.new("Frame")
                local initWidth = math.clamp((S.Value - opts.Min) / (opts.Max - opts.Min), 0, 1)
                fill.Size = UDim2.new(initWidth, 0, 1, 0)
                fill.BackgroundColor3 = AuraUI.Theme.Primary
                fill.BorderSizePixel = 0
                fill.Parent = trackBack
                Reg(fill, "BackgroundColor3", "Primary")
                
                local fc = Instance.new("UICorner")
                fc.CornerRadius = UDim.new(1, 0)
                fc.Parent = fill

                local thumb = Instance.new("Frame")
                thumb.Size = UDim2.new(0, 12, 0, 12)
                thumb.Position = UDim2.new(1, -6, 0.5, -6)
                thumb.BackgroundColor3 = Color3.new(1,1,1)
                thumb.BorderSizePixel = 0
                thumb.Parent = fill
                
                local tbc = Instance.new("UICorner")
                tbc.CornerRadius = UDim.new(1, 0)
                tbc.Parent = thumb
                
                local ts = Instance.new("UIStroke")
                ts.Color = AuraUI.Theme.Primary
                ts.Thickness = 2
                ts.Parent = thumb
                Reg(ts, "Color", "Primary")

                local trigger = Instance.new("TextButton")
                trigger.Size = UDim2.new(1, 0, 1, 0)
                trigger.BackgroundTransparency = 1
                trigger.Text = ""
                trigger.Parent = trackBack

                local dragging = false
                local function updateDrag(input)
                    local perc = math.clamp((input.Position.X - trackBack.AbsolutePosition.X) / trackBack.AbsoluteSize.X, 0, 1)
                    local rawVal = opts.Min + perc * (opts.Max - opts.Min)
                    if opts.Rounding then
                        rawVal = math.floor(rawVal / opts.Rounding + 0.5) * opts.Rounding
                    else
                        rawVal = math.floor(rawVal + 0.5)
                    end
                    rawVal = math.clamp(rawVal, opts.Min, opts.Max)
                    S.Value = rawVal
                    valLbl.Text = tostring(S.Value)
                    CreateTween(fill, {Size = UDim2.new((S.Value - opts.Min) / (opts.Max - opts.Min), 0, 1, 0)}, 0.1)
                    if opts.Callback then opts.Callback(S.Value) end
                end

                trigger.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        updateDrag(inp)
                        CreateTween(thumb, {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -8, 0.5, -8)}, 0.15)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                        CreateTween(thumb, {Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(1, -6, 0.5, -6)}, 0.15)
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then updateDrag(inp) end
                end)

                function S:SetValue(val)
                    S.Value = math.clamp(val, opts.Min, opts.Max)
                    valLbl.Text = tostring(S.Value)
                    CreateTween(fill, {Size = UDim2.new((S.Value - opts.Min) / (opts.Max - opts.Min), 0, 1, 0)}, 0.2)
                end

                AuraUI.Options[id] = S
                return S
            end

            function SectionData:AddDropdown(id, opts)
                local D = {Value = opts.Default, Values = opts.Values}
                local open = false

                local f = Instance.new("Frame")
                f.Size = UDim2.new(1, 0, 0, 42)
                f.BackgroundColor3 = AuraUI.Theme.Element
                f.BackgroundTransparency = 0.5
                f.ClipsDescendants = true
                f.Parent = SecContainer
                Reg(f, "BackgroundColor3", "Element")

                local fc = Instance.new("UICorner")
                fc.CornerRadius = UDim.new(0, 6)
                fc.Parent = f
                
                local fs = Instance.new("UIStroke")
                fs.Color = AuraUI.Theme.Border
                fs.Parent = f
                Reg(fs, "Color", "Border")

                local title = Instance.new("TextLabel")
                title.Size = UDim2.new(1, -30, 0, 42)
                title.Position = UDim2.new(0, 12, 0, 0)
                title.BackgroundTransparency = 1
                title.Text = opts.Title .. ": " .. tostring(D.Value)
                title.TextColor3 = AuraUI.Theme.TextMuted
                title.Font = Enum.Font.GothamMedium
                title.TextSize = 13
                title.TextXAlignment = Enum.TextXAlignment.Left
                title.Parent = f
                Reg(title, "TextColor3", "TextMuted")

                local chevron = Instance.new("TextLabel")
                chevron.Size = UDim2.new(0, 20, 0, 42)
                chevron.Position = UDim2.new(1, -26, 0, 0)
                chevron.BackgroundTransparency = 1
                chevron.Text = "▼"
                chevron.TextColor3 = AuraUI.Theme.TextMuted
                chevron.Font = Enum.Font.Gotham
                chevron.TextSize = 12
                chevron.Parent = f
                Reg(chevron, "TextColor3", "TextMuted")

                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 42)
                btn.BackgroundTransparency = 1
                btn.Text = ""
                btn.Parent = f

                local scroll = Instance.new("ScrollingFrame")
                scroll.Size = UDim2.new(1, -8, 1, -48)
                scroll.Position = UDim2.new(0, 4, 0, 44)
                scroll.BackgroundTransparency = 1
                scroll.ScrollBarThickness = 2
                scroll.Parent = f
                Reg(scroll, "ScrollBarImageColor3", "Border")

                local sLayout = Instance.new("UIListLayout")
                sLayout.SortOrder = Enum.SortOrder.LayoutOrder
                sLayout.Padding = UDim.new(0, 4)
                sLayout.Parent = scroll

                local function refresh()
                    for _, ch in ipairs(scroll:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
                    for _, val in ipairs(D.Values) do
                        local opt = Instance.new("TextButton")
                        opt.Size = UDim2.new(1, 0, 0, 28)
                        opt.BackgroundColor3 = AuraUI.Theme.Card
                        opt.BackgroundTransparency = 0.5
                        opt.Text = "  " .. val
                        opt.TextColor3 = (val == D.Value) and AuraUI.Theme.Primary or AuraUI.Theme.Text
                        opt.Font = Enum.Font.Gotham
                        opt.TextSize = 13
                        opt.TextXAlignment = Enum.TextXAlignment.Left
                        opt.AutoButtonColor = false
                        opt.Parent = scroll
                        
                        local oc = Instance.new("UICorner")
                        oc.CornerRadius = UDim.new(0, 6)
                        oc.Parent = opt

                        opt.MouseEnter:Connect(function() CreateTween(opt, {BackgroundTransparency = 0.2}, 0.15) end)
                        opt.MouseLeave:Connect(function() CreateTween(opt, {BackgroundTransparency = 0.5}, 0.15) end)
                        opt.MouseButton1Click:Connect(function()
                            D.Value = val
                            title.Text = opts.Title .. ": " .. tostring(val)
                            open = false
                            CreateTween(f, {Size = UDim2.new(1, 0, 0, 42)}, 0.3)
                            CreateTween(chevron, {Rotation = 0}, 0.3)
                            CreateTween(title, {TextColor3 = AuraUI.Theme.TextMuted}, 0.2)
                            CreateTween(fs, {Color = AuraUI.Theme.Border}, 0.2)
                            refresh()
                            if opts.Callback then opts.Callback(val) end
                        end)
                    end
                    scroll.CanvasSize = UDim2.new(0, 0, 0, sLayout.AbsoluteContentSize.Y)
                end

                btn.MouseButton1Click:Connect(function()
                    open = not open
                    refresh()
                    if open then
                        local expand = math.min(150, sLayout.AbsoluteContentSize.Y + 8)
                        CreateTween(f, {Size = UDim2.new(1, 0, 0, 46 + expand)}, 0.3, Enum.EasingStyle.Quart)
                        CreateTween(chevron, {Rotation = 180}, 0.3)
                        CreateTween(title, {TextColor3 = AuraUI.Theme.Text}, 0.2)
                        CreateTween(fs, {Color = AuraUI.Theme.Primary}, 0.2)
                    else
                        CreateTween(f, {Size = UDim2.new(1, 0, 0, 42)}, 0.3, Enum.EasingStyle.Quart)
                        CreateTween(chevron, {Rotation = 0}, 0.3)
                        CreateTween(title, {TextColor3 = AuraUI.Theme.TextMuted}, 0.2)
                        CreateTween(fs, {Color = AuraUI.Theme.Border}, 0.2)
                    end
                end)
                refresh()

                AuraUI.Options[id] = D
                return D
            end

            return SectionData
        end

        return TabData
    end

    -- Theme Settings Generation
    local SettingsTab = WindowData:AddTab("Settings", "rbxassetid://15222045585")
    local ThemeSec = SettingsTab:AddSection("Customization")
    
    local themeNames = {}
    for tName, _ in pairs(AuraUI.Themes) do table.insert(themeNames, tName) end
    
    ThemeSec:AddDropdown("ThemeDrop", {
        Title = "Hub Theme",
        Values = themeNames,
        Default = AuraUI.CurrentThemeName,
        Callback = function(val)
            AuraUI.CurrentThemeName = val
            UpdateTheme()
        end
    })

    return WindowData
end

function AuraUI:Notify(opts)
    local note = Instance.new("Frame")
    note.Size = UDim2.new(0, 280, 0, 60)
    note.Position = UDim2.new(1, 10, 1, -80)
    note.BackgroundColor3 = AuraUI.Theme.Card
    note.BackgroundTransparency = 0.1
    note.BorderSizePixel = 0
    note.Parent = (gethui and gethui()) or CoreGui

    local nc = Instance.new("UICorner")
    nc.CornerRadius = UDim.new(0, 8)
    nc.Parent = note

    local ns = Instance.new("UIStroke")
    ns.Color = AuraUI.Theme.Primary
    ns.Thickness = 1.5
    ns.Parent = note

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -20, 0, 20)
    title.Position = UDim2.new(0, 10, 0, 8)
    title.BackgroundTransparency = 1
    title.Text = opts.Title or "Notification"
    title.TextColor3 = AuraUI.Theme.Text
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = note

    local desc = Instance.new("TextLabel")
    desc.Size = UDim2.new(1, -20, 0, 20)
    desc.Position = UDim2.new(0, 10, 0, 30)
    desc.BackgroundTransparency = 1
    desc.Text = opts.Content or ""
    desc.TextColor3 = AuraUI.Theme.TextMuted
    desc.Font = Enum.Font.Gotham
    desc.TextSize = 12
    desc.TextXAlignment = Enum.TextXAlignment.Left
    desc.Parent = note

    CreateTween(note, {Position = UDim2.new(1, -300, 1, -80)}, 0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    task.wait(opts.Duration or 3)
    CreateTween(note, {Position = UDim2.new(1, 10, 1, -80)}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    task.delay(0.4, function() note:Destroy() end)
end

return AuraUI
