-- ─── Utilities ──────────────────────────────────────────────────────────────
local function PlaySound(id, vol, pitch) 
    if not id or id == "" then return end 
    task.spawn(function() 
        local s = Instance.new("Sound") 
        s.SoundId = id 
        s.Volume = vol or 0.3 
        s.PlaybackSpeed = (pitch and pitch < 0) and math.abs(pitch) * 0.75 or (pitch or 1) 
        s.Parent = CoreGui 
        local t = tick() 
        while not s.IsLoaded and tick() - t < 0.5 do task.wait() end 
        s:Play() 
        s.Ended:Connect(function() s:Destroy() end) 
        Debris:AddItem(s, 3) 
    end) 
end 
 
local function Tween(inst, props, dur, style, dir) 
    local ti = TweenInfo.new(dur or 0.15, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out) 
    local tw = TweenService:Create(inst, ti, props) 
    tw:Play() 
    return tw 
end 
 
local function Reg(obj, prop, key) 
    AuraUI.ThemeObjects[obj] = {Prop = prop, Key = key} 
    obj[prop] = AuraUI.Theme[key] 
end 
 
local function UpdateTheme() 
    local t = AuraUI.Themes[AuraUI.CurrentThemeName] 
    AuraUI.Theme = t 
    for obj, data in pairs(AuraUI.ThemeObjects) do 
        if obj and obj.Parent then 
            Tween(obj, {[data.Prop] = t[data.Key]}, 0.25) 
        else 
            AuraUI.ThemeObjects[obj] = nil 
        end 
    end 
end 
 
local function Corner(parent, r) 
    local c = Instance.new("UICorner") 
    c.CornerRadius = UDim.new(0, r or 6) 
    c.Parent = parent 
    return c 
end 
 
local function MakeStroke(parent, color, thick) 
    local s = Instance.new("UIStroke") 
    s.Color = color or AuraUI.Theme.Stroke 
    s.Thickness = thick or 1 
    s.Transparency = 0.5
    s.Parent = parent 
    return s 
end 

