-- ── CONFIG SYSTEM ─────────────────────────────────────────────────────────────
local ConfigSystem = { Folder = "AuraSettings", Ignore = {} }

function ConfigSystem:BuildFolderTree()
    for _, p in ipairs({self.Folder, self.Folder.."/settings"}) do
        if not isfolder(p) then makefolder(p) end
    end
end
ConfigSystem:BuildFolderTree()

function ConfigSystem:Save(name)
    if not name or name == "" then return false, "no config name" end
    local data = {objects = {}}
    for idx, opt in pairs(AuraUI.Options) do
        if self.Ignore[idx] then continue end
        local s
        if opt.Type == "Toggle" then s = {type = "Toggle", idx = idx, value = opt.Value}
        elseif opt.Type == "Slider" then s = {type = "Slider", idx = idx, value = opt.Value}
        elseif opt.Type == "Dropdown" then s = {type = "Dropdown", idx = idx, value = opt.Value}
        elseif opt.Type == "Input" then s = {type = "Input", idx = idx, text = opt.Value}
        elseif opt.Type == "Keybind" then s = {type = "Keybind", idx = idx, key = opt.Value}
        elseif opt.Type == "Colorpicker" then s = {type = "Colorpicker", idx = idx, r = math.floor(opt.Value.R * 255), g = math.floor(opt.Value.G * 255), b = math.floor(opt.Value.B * 255)} end
        if s then table.insert(data.objects, s) end
    end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then return false, "failed to encode" end
    writefile(self.Folder .. "/settings/" .. name .. ".json", encoded)
    return true
end

function ConfigSystem:Load(name)
    if not name or name == "" then return false, "no config name" end
    local file = self.Folder .. "/settings/" .. name .. ".json"
    if not isfile(file) then return false, "file not found" end
    local ok, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(file))
    if not ok then return false, "decode error" end
    for _, opt in pairs(decoded.objects) do
        local configOpt = AuraUI.Options[opt.idx]
        if configOpt then
            if opt.type == "Toggle" and configOpt.SetValue then configOpt:SetValue(opt.value)
            elseif opt.type == "Slider" and configOpt.SetValue then configOpt:SetValue(opt.value)
            elseif opt.type == "Dropdown" and configOpt.SetValue then configOpt:SetValue(opt.value)
            elseif opt.type == "Input" and configOpt.SetValue then configOpt:SetValue(opt.text)
            elseif opt.type == "Keybind" and configOpt.SetValue then configOpt:SetValue(opt.key)
            elseif opt.type == "Colorpicker" and configOpt.SetValueRGB then configOpt:SetValueRGB(Color3.fromRGB(opt.r, opt.g, opt.b)) end
        end
    end
    return true
end

function ConfigSystem:RefreshList()
    local out = {}
    for _, file in ipairs(listfiles(self.Folder .. "/settings")) do
        if file:sub(-5) == ".json" then
            local name = file:match("([^/\\]+)%.json$")
            if name and name ~= "options" and name ~= "autoload" then table.insert(out, name) end
        end
    end
    return out
end

function ConfigSystem:LoadAutoload()
    if isfile(self.Folder .. "/settings/autoload.txt") then
        local name = readfile(self.Folder .. "/settings/autoload.txt")
        if self:Load(name) then
            AuraUI:Notify({Title = "Aura UI", Content = "Auto-loaded config: " .. name, Duration = 5})
        end
    end
end

-- ── SOUNDS & UTILITIES ────────────────────────────────────────────────────────
local Sounds = { click = "rbxassetid://6895079853", hover = "rbxassetid://6895079853", whoosh = "rbxassetid://1177785010", toggle = "rbxassetid://6895079853", open = "rbxassetid://6869244313" }

local function playSound(id, vol, pitch)
    local s = Instance.new("Sound")
    s.SoundId = id; s.Volume = vol or 0.5; s.PlaybackSpeed = pitch or 1
    s.Parent = game:GetService("SoundService"); s:Play()
    game:GetService("Debris"):AddItem(s, 2)
end

local function tw(obj, props, t)
    local tween = TweenService:Create(obj, TweenInfo.new(t or 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tween:Play(); return tween
end

local function applyThemeList(list)
    for _, r in ipairs(list) do pcall(function() r.obj[r.prop] = currentTheme[r.key] end) end
end

-- Colorpicker Utility (HSV conversions)
local function color3ToHsv(c)
    local r, g, b = c.R, c.G, c.B
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, max
    local d = max - min
    if max ~= 0 then s = d / max end
    if d ~= 0 then
        if max == r then h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then h = (b - r) / d + 2
        else h = (r - g) / d + 4 end
        h = h / 6
    end
    return h, s, v
end
local function hsvToColor3(h, s, v)
    local r, g, b
    local i = math.floor(h * 6); local f = h * 6 - i; local p = v * (1 - s); local q = v * (1 - f * s); local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then r, g, b = v, t, p
    elseif i == 1 then r, g, b = q, v, p
    elseif i == 2 then r, g, b = p, v, t
    elseif i == 3 then r, g, b = p, q, v
    elseif i == 4 then r, g, b = t, p, v
    elseif i == 5 then r, g, b = v, p, q end
    return Color3.new(r, g, b)
end

-- Ambient particles
local function createParticle(parent)
    local p = Instance.new("Frame")
    p.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
    p.Position = UDim2.new(math.random(), 0, math.random(), 0)
    p.BackgroundColor3 = currentTheme.particleColor; p.BackgroundTransparency = 0.6; p.BorderSizePixel = 0
    p.ZIndex = 1; p.Parent = parent
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(1, 0); c.Parent = p
    task.spawn(function()
        while p.Parent do
            local dur = 3 + math.random() * 3
            p.BackgroundColor3 = currentTheme.particleColor
            tw(p, {Position = UDim2.new(math.random(), 0, math.random(), 0), BackgroundTransparency = 0.4 + math.random() * 0.4}, dur)
            task.wait(dur)
        end
    end)
end

