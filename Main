            table.insert(Window._reg, {obj = f, prop = "BackgroundColor3", key = "topbar"}); table.insert(Window._reg, {obj = s, prop = "Color", key = "primary"})
            f.MouseEnter:Connect(function() tw(s, {Transparency = 0.3}, 0.2); tw(f, {BackgroundTransparency = 0.1}, 0.2) end); f.MouseLeave:Connect(function() tw(s, {Transparency = 0.8}, 0.2); tw(f, {BackgroundTransparency = 0.5}, 0.2) end)
            return f
        end

        local function addLbl(p, txt, s, f, col, ax, px, py)
            local l = Instance.new("TextLabel"); l.Size = UDim2.new(1, -50, 0, 15); l.Position = UDim2.new(0, px or 12, 0, py or 12)
            l.BackgroundTransparency = 1; l.Text = txt; l.Font = f; l.TextColor3 = col; l.TextSize = s; l.TextXAlignment = ax or Enum.TextXAlignment.Left; l.Parent = p; return l
        end

        function Tab:AddButton(n, c)
            local hasD = false; local f = baseObj(32)
            local t = addLbl(f, n, 13, Enum.Font.GothamMedium, currentTheme.text, nil, 12, 8)
            t.Size = UDim2.new(1, -20, 0, 16)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            
            local b = Instance.new("TextButton"); b.Size = UDim2.new(1, 0, 1, 0); b.BackgroundTransparency = 1; b.Text = ""; b.ZIndex = 5; b.Parent = f
            b.MouseEnter:Connect(function() playSound(Sounds.hover, 0.2, 1); tw(f, {BackgroundColor3 = currentTheme.primary, BackgroundTransparency = 0.5}, 0.15) end)
            b.MouseLeave:Connect(function() tw(f, {BackgroundColor3 = currentTheme.topbar, BackgroundTransparency = 0.5}, 0.15) end)
            b.MouseButton1Click:Connect(function() playSound(Sounds.click, 0.4, 1); createRipple(b); if c.Callback then c.Callback() end end)
        end

        function Tab:AddToggle(n, c)
            local T = {Value = c.Default or false, Name = n, Type = "Toggle"}
            local f = baseObj(40)
            local t = addLbl(f, c.Title or n, 14, Enum.Font.GothamSemibold, currentTheme.text, nil, 12, 0); t.Size = UDim2.new(1, -70, 1, 0)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            local trk = Instance.new("Frame"); trk.Size = UDim2.new(0, 42, 0, 20); trk.Position = UDim2.new(1, -54, 0.5, 0); trk.AnchorPoint = Vector2.new(0, 0.5); trk.BackgroundColor3 = currentTheme.topbar; trk.Parent = f
            local tkc = Instance.new("UICorner"); tkc.CornerRadius = UDim.new(1, 0); tkc.Parent = trk
            local knb = Instance.new("Frame"); knb.Size = UDim2.new(0, 16, 0, 16); knb.Position = UDim2.new(0, 2, 0.5, 0); knb.AnchorPoint = Vector2.new(0, 0.5); knb.BackgroundColor3 = currentTheme.textDim; knb.Parent = trk
            local knc = Instance.new("UICorner"); knc.CornerRadius = UDim.new(1, 0); knc.Parent = knb
            
            local function upd()
                if T.Value then tw(trk, {BackgroundColor3 = currentTheme.primary}, 0.25); tw(knb, {Position = UDim2.new(1, -18, 0.5, 0), BackgroundColor3 = Color3.new(1,1,1)}, 0.25)
                else tw(trk, {BackgroundColor3 = currentTheme.topbar}, 0.25); tw(knb, {Position = UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = currentTheme.textDim}, 0.25) end
            end
            local b = Instance.new("TextButton"); b.Size = UDim2.new(1, 0, 1, 0); b.BackgroundTransparency = 1; b.Text = ""; b.ZIndex = 5; b.Parent = f
            b.MouseButton1Click:Connect(function() T.Value = not T.Value; playSound(Sounds.toggle, 0.4, T.Value and 0.9 or 1.1); upd(); if c.Callback then c.Callback(T.Value) end end)
            function T:SetValue(v) T.Value = v; upd() end; upd(); AuraUI.Options[n] = T; return T
        end

        function Tab:AddSlider(n, c)
            local Sl = {Value = math.clamp(c.Default or c.Min or 0, c.Min or 0, c.Max or 100), Min = c.Min or 0, Max = c.Max or 100, Rounding = c.Rounding or 1, Name = n, Type = "Slider"}
            if Sl.Min > Sl.Max then Sl.Min, Sl.Max = Sl.Max, Sl.Min end; if Sl.Min == Sl.Max then Sl.Max = Sl.Min + 100 end

            local f = baseObj(50)
            local t = addLbl(f, c.Title or n, 13, Enum.Font.GothamSemibold, currentTheme.text, nil, 12, 6); t.Size = UDim2.new(0.6, 0, 0, 18)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            local vt = addLbl(f, tostring(Sl.Value), 13, Enum.Font.GothamBold, currentTheme.primary, Enum.TextXAlignment.Right, 0, 6); vt.Size = UDim2.new(0.4, -12, 0, 18); vt.Position = UDim2.new(0.6, 0, 0, 6)
            table.insert(Window._reg, {obj = vt, prop = "TextColor3", key = "primary"})
            
            local trk = Instance.new("Frame"); trk.Size = UDim2.new(1, -24, 0, 4); trk.Position = UDim2.new(0, 12, 1, -14); trk.BackgroundColor3 = currentTheme.topbar; trk.Parent = f
            table.insert(Window._reg, {obj = trk, prop = "BackgroundColor3", key = "topbar"}); local tc = Instance.new("UICorner"); tc.CornerRadius = UDim.new(1, 0); tc.Parent = trk
            local fil = Instance.new("Frame"); fil.Size = UDim2.new(0, 0, 1, 0); fil.BackgroundColor3 = currentTheme.primary; fil.Parent = trk
            table.insert(Window._reg, {obj = fil, prop = "BackgroundColor3", key = "primary"}); local fc = Instance.new("UICorner"); fc.CornerRadius = UDim.new(1, 0); fc.Parent = fil
            local knb = Instance.new("Frame"); knb.Size = UDim2.new(0, 12, 0, 12); knb.AnchorPoint = Vector2.new(0.5, 0.5); knb.Position = UDim2.new(0, 0, 0.5, 0); knb.BackgroundColor3 = currentTheme.primary; knb.Parent = trk; local kc = Instance.new("UICorner"); kc.CornerRadius = UDim.new(1, 0); kc.Parent = knb
            table.insert(Window._reg, {obj = knb, prop = "BackgroundColor3", key = "primary"})

            local drag = false
            local function upS(inp)
                local p = math.clamp((inp.Position.X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X, 0, 1)
                local v = Sl.Min + p * (Sl.Max - Sl.Min)
                if Sl.Rounding > 0 then v = math.floor(v / Sl.Rounding + 0.5) * Sl.Rounding else v = math.floor(v + 0.5) end
                v = math.clamp(v, Sl.Min, Sl.Max); Sl.Value = v; vt.Text = tostring(v)
                tw(fil, {Size = UDim2.new(p, 0, 1, 0)}, 0.08); tw(knb, {Position = UDim2.new(p, 0, 0.5, 0)}, 0.08)
                if c.Callback then c.Callback(v) end
            end
            local ta = Instance.new("TextButton"); ta.Size = UDim2.new(1, 0, 0, 24); ta.Position = UDim2.new(0, 0, 1, -24); ta.BackgroundTransparency = 1; ta.Text = ""; ta.ZIndex = 5; ta.Parent = f
            ta.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; upS(inp) end end)
            ta.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
            UserInputService.InputChanged:Connect(function(inp) if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then upS(inp) end end)
            
            function Sl:SetValue(v)
                Sl.Value = math.clamp(v, Sl.Min, Sl.Max); vt.Text = tostring(Sl.Value)
                local pos = (Sl.Value - Sl.Min) / (Sl.Max - Sl.Min)
                tw(fil, {Size = UDim2.new(pos, 0, 1, 0)}, 0.2); tw(knb, {Position = UDim2.new(pos, 0, 0.5, 0)}, 0.2)
            end
            Sl:SetValue(Sl.Value); AuraUI.Options[n] = Sl; return Sl
        end

        function Tab:AddMultiDropdown(n, c)
            local MD = {Value = c.Default or {}, Items = c.Values or {}, Name = n, Type = "MultiDropdown"}
            local opn = false; local f = baseObj(36); f.ClipsDescendants = false
            local t = addLbl(f, c.Title or n, 12, Enum.Font.GothamMedium, currentTheme.text, nil, 14, 0); t.Size = UDim2.new(1, -90, 1, 0)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            
            local function count() local x=0; for _ in pairs(MD.Value) do x=x+1 end; return x end
            local ct = addLbl(f, count() .. " selected", 11, Enum.Font.Gotham, currentTheme.textDim, Enum.TextXAlignment.Right, 0, 0); ct.Size = UDim2.new(0, 60, 1, 0); ct.Position = UDim2.new(1, -88, 0, 0)
            table.insert(Window._reg, {obj = ct, prop = "TextColor3", key = "textDim"})

            local arr = addLbl(f, "▼", 10, Enum.Font.Gotham, currentTheme.primary, Enum.TextXAlignment.Right, 0, 0); arr.Size = UDim2.new(0, 22, 1, 0); arr.Position = UDim2.new(1, -28, 0, 0)
            table.insert(Window._reg, {obj = arr, prop = "TextColor3", key = "primary"})

            local scr = Instance.new("ScrollingFrame"); scr.Size = UDim2.new(1, 0, 0, 0); scr.Position = UDim2.new(0, 0, 0, 40); scr.BackgroundColor3 = currentTheme.background; scr.BorderSizePixel = 0; scr.ScrollBarThickness = 2; scr.Visible = false; scr.ZIndex = 12; scr.Parent = f
            table.insert(Window._reg, {obj = scr, prop = "BackgroundColor3", key = "background"})
            local scrc = Instance.new("UICorner"); scrc.CornerRadius = UDim.new(0, 6); scrc.Parent = scr
            local scrs = Instance.new("UIStroke"); scrs.Color = currentTheme.primary; scrs.Thickness = 1; scrs.Transparency = 0.5; scrs.Parent = scr
            table.insert(Window._reg, {obj = scrs, prop = "Color", key = "primary"})

            local ssl = Instance.new("UIListLayout"); ssl.SortOrder = Enum.SortOrder.LayoutOrder; ssl.Padding = UDim.new(0, 2); ssl.Parent = scr
            ssl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scr.CanvasSize = UDim2.new(0, 0, 0, ssl.AbsoluteContentSize.Y + 8) end)

            local function bld()
                for _, ch in ipairs(scr:GetChildren()) do if ch:IsA("Frame") then ch:Destroy() end end
                for _, itm in ipairs(MD.Items) do
                    local rw = Instance.new("Frame"); rw.Size = UDim2.new(1, -8, 0, 26); rw.Position = UDim2.new(0, 4, 0, 0); rw.BackgroundColor3 = currentTheme.topbar; rw.ZIndex = 13; rw.Parent = scr; local rc = Instance.new("UICorner"); rc.CornerRadius = UDim.new(0, 4); rc.Parent = rw
                    table.insert(Window._reg, {obj = rw, prop = "BackgroundColor3", key = "topbar"})
                    local tl = Instance.new("TextLabel"); tl.Size = UDim2.new(1, -30, 1, 0); tl.Position = UDim2.new(0, 8, 0, 0); tl.BackgroundTransparency = 1; tl.Text = itm; tl.TextColor3 = MD.Value[itm] and currentTheme.primary or currentTheme.text; tl.TextSize = 12; tl.Font = Enum.Font.Gotham; tl.TextXAlignment = Enum.TextXAlignment.Left; tl.ZIndex = 14; tl.Parent = rw
                    table.insert(Window._reg, {obj = tl, prop = "TextColor3", key = MD.Value[itm] and "primary" or "text"})
                    
                    local ck = Instance.new("Frame"); ck.Size = UDim2.new(0, 14, 0, 14); ck.Position = UDim2.new(1, -22, 0.5, 0); ck.AnchorPoint = Vector2.new(0, 0.5); ck.BackgroundColor3 = MD.Value[itm] and currentTheme.primary or currentTheme.background; ck.ZIndex = 14; ck.Parent = rw
                    local ckc = Instance.new("UICorner"); ckc.CornerRadius = UDim.new(0, 4); ckc.Parent = ck
                    table.insert(Window._reg, {obj = ck, prop = "BackgroundColor3", key = MD.Value[itm] and "primary" or "background"})

                    local btn = Instance.new("TextButton"); btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1; btn.Text = ""; btn.ZIndex = 15; btn.Parent = rw
                    btn.MouseEnter:Connect(function() tw(rw, {BackgroundColor3 = currentTheme.primary}, 0.15); tw(tl, {TextColor3 = Color3.new(1,1,1)}, 0.15) end)
                    btn.MouseLeave:Connect(function() tw(rw, {BackgroundColor3 = currentTheme.topbar}, 0.15); tw(tl, {TextColor3 = MD.Value[itm] and currentTheme.primary or currentTheme.text}, 0.15) end)
                    btn.MouseButton1Click:Connect(function()
                        if MD.Value[itm] then MD.Value[itm] = nil else MD.Value[itm] = true end
                        ct.Text = count() .. " selected"; bld(); if c.Callback then c.Callback(MD.Value) end
                    end)
                end
            end
            bld()

            local bt = Instance.new("TextButton"); bt.Size = UDim2.new(1, -26, 0, 36); bt.BackgroundTransparency = 1; bt.Text = ""; bt.ZIndex = 5; bt.Parent = f
            bt.MouseButton1Click:Connect(function()
                opn = not opn
                if opn then
                    scr.Visible = true; local h = math.min(140, ssl.AbsoluteContentSize.Y + 8)
                    tw(f, {Size = UDim2.new(1, 0, 0, 42 + h)}, 0.25); tw(scr, {Size = UDim2.new(1, 0, 0, h)}, 0.25); tw(arr, {Rotation = 180}, 0.25)
                    tw(t, {TextTransparency = 1}, 0.15); tw(ct, {TextTransparency = 1}, 0.15)
                else
                    tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.25); tw(scr, {Size = UDim2.new(1, 0, 0, 0)}, 0.25); tw(arr, {Rotation = 0}, 0.25); tw(t, {TextTransparency = 0}, 0.15); tw(ct, {TextTransparency = 0}, 0.15); task.wait(0.26); scr.Visible = false
                end
            end)

            function MD:SetValue(tVals) MD.Value = tVals; ct.Text = count() .. " selected"; bld() end
            AuraUI.Options[n] = MD; return MD
        end
            local D = {Value = c.Default, Values = c.Values or {}, Name = n, Type = "Dropdown"}
            local opn = false; local f = baseObj(36); f.ClipsDescendants = false
            local t = addLbl(f, c.Title or n, 12, Enum.Font.GothamMedium, currentTheme.text, nil, 14, 0); t.Size = UDim2.new(1, -40, 1, 0)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            local arr = addLbl(f, "▼", 10, Enum.Font.Gotham, currentTheme.primary, Enum.TextXAlignment.Right, 0, 0); arr.Size = UDim2.new(0, 22, 1, 0); arr.Position = UDim2.new(1, -28, 0, 0)
            table.insert(Window._reg, {obj = arr, prop = "TextColor3", key = "primary"})
            
            local scr = Instance.new("ScrollingFrame"); scr.Size = UDim2.new(1, 0, 0, 0); scr.Position = UDim2.new(0, 0, 0, 40); scr.BackgroundColor3 = currentTheme.background; scr.BorderSizePixel = 0; scr.ScrollBarThickness = 2; scr.Visible = false; scr.ZIndex = 12; scr.Parent = f
            table.insert(Window._reg, {obj = scr, prop = "BackgroundColor3", key = "background"})
            local scrc = Instance.new("UICorner"); scrc.CornerRadius = UDim.new(0, 6); scrc.Parent = scr
            local scrs = Instance.new("UIStroke"); scrs.Color = currentTheme.primary; scrs.Thickness = 1; scrs.Transparency = 0.5; scrs.Parent = scr
            table.insert(Window._reg, {obj = scrs, prop = "Color", key = "primary"})

            local ssl = Instance.new("UIListLayout"); ssl.SortOrder = Enum.SortOrder.LayoutOrder; ssl.Padding = UDim.new(0, 2); ssl.Parent = scr
            ssl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scr.CanvasSize = UDim2.new(0, 0, 0, ssl.AbsoluteContentSize.Y + 8) end)

            local function redraw()
                for _, ch in ipairs(scr:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
                for _, val in ipairs(D.Values) do
                    local ob = Instance.new("TextButton"); ob.Size = UDim2.new(1, -8, 0, 26); ob.Position = UDim2.new(0, 4, 0, 0); ob.BackgroundColor3 = currentTheme.topbar; ob.Text = "  " .. val; ob.TextColor3 = currentTheme.text; ob.TextSize = 12; ob.Font = Enum.Font.Gotham; ob.TextXAlignment = Enum.TextXAlignment.Left; ob.ZIndex = 13; ob.Parent = scr
                    table.insert(Window._reg, {obj = ob, prop = "BackgroundColor3", key = "topbar"}); table.insert(Window._reg, {obj = ob, prop = "TextColor3", key = "text"})
                    local oc = Instance.new("UICorner"); oc.CornerRadius = UDim.new(0, 4); oc.Parent = ob
                    ob.MouseButton1Click:Connect(function()
                        D.Value = val; t.Text = c.Title and (c.Title .. "  (" .. val .. ")") or val
                        opn = false; tw(arr, {Rotation = 0}, 0.25); tw(t, {TextTransparency = 0}, 0.15)
                        tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.25); tw(scr, {Size = UDim2.new(1, 0, 0, 0)}, 0.25); task.wait(0.26); scr.Visible = false
                        if c.Callback then c.Callback(val) end
                    end)
                    ob.MouseEnter:Connect(function() tw(ob, {BackgroundColor3 = currentTheme.primary}, 0.15) end); ob.MouseLeave:Connect(function() tw(ob, {BackgroundColor3 = currentTheme.topbar}, 0.15) end)
                end
            end
            redraw(); if D.Value then t.Text = c.Title and (c.Title .. "  (" .. D.Value .. ")") or D.Value end
            
            local bt = Instance.new("TextButton"); bt.Size = UDim2.new(1, -26, 0, 36); bt.BackgroundTransparency = 1; bt.Text = ""; bt.ZIndex = 5; bt.Parent = f
            bt.MouseButton1Click:Connect(function()
                opn = not opn
                if opn then
                    scr.Visible = true; local h = math.min(140, ssl.AbsoluteContentSize.Y + 8)
                    tw(f, {Size = UDim2.new(1, 0, 0, 42 + h)}, 0.25); tw(scr, {Size = UDim2.new(1, 0, 0, h)}, 0.25); tw(arr, {Rotation = 180}, 0.25)
                    tw(t, {TextTransparency = 1}, 0.15) -- Hide name while open per user request
                else
                    tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.25); tw(scr, {Size = UDim2.new(1, 0, 0, 0)}, 0.25); tw(arr, {Rotation = 0}, 0.25); tw(t, {TextTransparency = 0}, 0.15); task.wait(0.26); scr.Visible = false
                end
            end)

            function D:SetValue(v) D.Value = v; t.Text = c.Title and (c.Title .. "  (" .. v .. ")") or v end
            function D:SetValues(v) D.Values = v; redraw() end
            AuraUI.Options[n] = D; return D
        end

        function Tab:AddInput(n, c)
            local I = {Value = c.Default or "", Name = n, Type = "Input"}
            local f = baseObj(45)
            local t = addLbl(f, c.Title or n, 13, Enum.Font.GothamSemibold, currentTheme.text, nil, 12, 4)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            
            local bx = Instance.new("TextBox"); bx.Size = UDim2.new(1, -24, 0, 22); bx.Position = UDim2.new(0, 12, 0, 19); bx.BackgroundColor3 = currentTheme.topbar; bx.Text = I.Value; bx.PlaceholderText = c.Placeholder or ""; bx.TextColor3 = currentTheme.text; bx.PlaceholderColor3 = currentTheme.textDim; bx.TextSize = 13; bx.Font = Enum.Font.Gotham; bx.TextXAlignment = Enum.TextXAlignment.Left; bx.ClearTextOnFocus = false; bx.Parent = f
            local bxc = Instance.new("UICorner"); bxc.CornerRadius = UDim.new(0, 6); bxc.Parent = bx; local bp = Instance.new("UIPadding"); bp.PaddingLeft = UDim.new(0, 6); bp.PaddingRight = UDim.new(0, 6); bp.Parent = bx
            table.insert(Window._reg, {obj = bx, prop = "BackgroundColor3", key = "topbar"}); table.insert(Window._reg, {obj = bx, prop = "TextColor3", key = "text"}); table.insert(Window._reg, {obj = bx, prop = "PlaceholderColor3", key = "textDim"})

            bx.FocusLost:Connect(function() I.Value = bx.Text; if c.Callback then c.Callback(bx.Text) end end)
            if c.Numeric then bx:GetPropertyChangedSignal("Text"):Connect(function() bx.Text = bx.Text:gsub("[^%d]", "") end) end
            
            function I:SetValue(v) bx.Text = v; I.Value = v end
            AuraUI.Options[n] = I; return I
        end

        function Tab:AddColorpicker(n, c)
            local CP = {Value = c.Default or Color3.fromRGB(255, 255, 255), Name = n, Type = "Colorpicker"}
            local h, s, v = color3ToHsv(CP.Value); local opn = false
            local f = baseObj(36); f.ClipsDescendants = false
            local t = addLbl(f, c.Title or n, 12, Enum.Font.GothamMedium, currentTheme.text, nil, 14, 0); t.Size = UDim2.new(1, -60, 1, 0)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            
            local sw = Instance.new("TextButton"); sw.Size = UDim2.new(0, 30, 0, 18); sw.Position = UDim2.new(1, -40, 0.5, 0); sw.AnchorPoint = Vector2.new(0, 0.5); sw.BackgroundColor3 = CP.Value; sw.Text = ""; sw.ZIndex = 6; sw.Parent = f
            local swc = Instance.new("UICorner"); swc.CornerRadius = UDim.new(0, 4); swc.Parent = sw
            local sws = Instance.new("UIStroke"); sws.Color = Color3.new(1,1,1); sws.Thickness = 1; sws.Transparency = 0.5; sws.Parent = sw
            
            local pan = Instance.new("Frame"); pan.Size = UDim2.new(1, 0, 0, 0); pan.Position = UDim2.new(0, 0, 0, 40); pan.BackgroundColor3 = currentTheme.background; pan.Visible = false; pan.ZIndex = 14; pan.ClipsDescendants = true; pan.Parent = f
            table.insert(Window._reg, {obj = pan, prop = "BackgroundColor3", key = "background"}); local pc = Instance.new("UICorner"); pc.CornerRadius = UDim.new(0, 6); pc.Parent = pan
            local ps = Instance.new("UIStroke"); ps.Color = currentTheme.primary; ps.Thickness = 1; ps.Transparency = 0.5; ps.Parent = pan
            table.insert(Window._reg, {obj = ps, prop = "Color", key = "primary"})

            local svy = Instance.new("ImageLabel"); svy.Size = UDim2.new(1, -16, 0, 110); svy.Position = UDim2.new(0, 8, 0, 8); svy.Image = "rbxassetid://4155801252"; svy.BackgroundColor3 = hsvToColor3(h, 1, 1); svy.ZIndex = 15; svy.Parent = pan
            local svc = Instance.new("UICorner"); svc.CornerRadius = UDim.new(0, 4); svc.Parent = svy
            local svknb = Instance.new("Frame"); svknb.Size = UDim2.new(0, 10, 0, 10); svknb.AnchorPoint = Vector2.new(0.5, 0.5); svknb.BackgroundColor3 = Color3.new(1, 1, 1); svknb.ZIndex = 16; svknb.Parent = svy; local skc = Instance.new("UICorner"); skc.CornerRadius = UDim.new(1, 0); skc.Parent = svknb
            
            local hue = Instance.new("ImageLabel"); hue.Size = UDim2.new(1, -16, 0, 12); hue.Position = UDim2.new(0, 8, 0, 124); hue.Image = "rbxassetid://698052001"; hue.BackgroundColor3 = Color3.new(1,1,1); hue.ZIndex = 15; hue.Parent = pan; local hc = Instance.new("UICorner"); hc.CornerRadius = UDim.new(1, 0); hc.Parent = hue
            local hknb = Instance.new("Frame"); hknb.Size = UDim2.new(0, 6, 1, 4); hknb.AnchorPoint = Vector2.new(0.5, 0.5); hknb.BackgroundColor3 = Color3.new(1, 1, 1); hknb.ZIndex = 16; hknb.Parent = hue; local hkc = Instance.new("UICorner"); hkc.CornerRadius = UDim.new(0, 4); hkc.Parent = hknb

            local function upd()
                CP.Value = hsvToColor3(h, s, v); sw.BackgroundColor3 = CP.Value; svy.BackgroundColor3 = hsvToColor3(h, 1, 1)
                svknb.Position = UDim2.new(s, 0, 1 - v, 0); hknb.Position = UDim2.new(h, 0, 0.5, 0)
                if c.Callback then c.Callback(CP.Value) end
            end

            local svDrag, hueDrag = false, false
            local svBtn = Instance.new("TextButton"); svBtn.Size = UDim2.new(1, 0, 1, 0); svBtn.BackgroundTransparency = 1; svBtn.Text = ""; svBtn.ZIndex = 17; svBtn.Parent = svy
            svBtn.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = true end end)
            local hBtn = Instance.new("TextButton"); hBtn.Size = UDim2.new(1, 0, 1, 0); hBtn.BackgroundTransparency = 1; hBtn.Text = ""; hBtn.ZIndex = 17; hBtn.Parent = hue
            hBtn.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = true end end)

            local function releaseDrag()
                if svDrag or hueDrag then
                    svDrag = false; hueDrag = false
                    -- Auto-close when released per user request
                    if opn then
                        opn = false
                        tw(t, {TextTransparency = 0}, 0.15)
                        tw(pan, {Size = UDim2.new(1, 0, 0, 0)}, 0.2); tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.2); task.wait(0.22); pan.Visible = false
                    end
                end
            end

            UserInputService.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    if svDrag then s = math.clamp((inp.Position.X - svy.AbsolutePosition.X) / svy.AbsoluteSize.X, 0, 1); v = 1 - math.clamp((inp.Position.Y - svy.AbsolutePosition.Y) / svy.AbsoluteSize.Y, 0, 1); upd()
                    elseif hueDrag then h = math.clamp((inp.Position.X - hue.AbsolutePosition.X) / hue.AbsoluteSize.X, 0, 1); upd() end
                end
            end)
            UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then releaseDrag() end end)
            upd()

            sw.MouseButton1Click:Connect(function()
                opn = not opn
                if opn then pan.Visible = true; tw(t, {TextTransparency = 1}, 0.15); tw(pan, {Size = UDim2.new(1, 0, 0, 144)}, 0.25); tw(f, {Size = UDim2.new(1, 0, 0, 188)}, 0.25)
                else tw(t, {TextTransparency = 0}, 0.15); tw(pan, {Size = UDim2.new(1, 0, 0, 0)}, 0.2); tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.2); task.wait(0.22); pan.Visible = false end
            end)
            
            -- Adding an explicit Confirm button for colorpickers (clicking empty space)
            local cBtn = Instance.new("TextButton"); cBtn.Size = UDim2.new(1, -40, 0, 36); cBtn.BackgroundTransparency = 1; cBtn.Text = ""; cBtn.ZIndex = 5; cBtn.Parent = f
            cBtn.MouseButton1Click:Connect(function()
                if opn then
                    opn = false
                    tw(t, {TextTransparency = 0}, 0.15)
                    tw(pan, {Size = UDim2.new(1, 0, 0, 0)}, 0.2); tw(f, {Size = UDim2.new(1, 0, 0, 36)}, 0.2); task.wait(0.22); pan.Visible = false
                end
            end)

            function CP:SetValueRGB(col) CP.Value = col; sw.BackgroundColor3 = col; h, s, v = color3ToHsv(col); upd() end
            AuraUI.Options[n] = CP; return CP
        end

        function Tab:AddKeybind(n, c)
            local K = {Value = c.Default or "None", Name = n, Type = "Keybind"}
            local f = baseObj(38)
            local t = addLbl(f, c.Title or n, 13, Enum.Font.GothamSemibold, currentTheme.text, nil, 12, 0); t.Size = UDim2.new(1, -90, 1, 0)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "text"})
            
            local kbtn = Instance.new("TextButton"); kbtn.Size = UDim2.new(0, 75, 0, 24); kbtn.Position = UDim2.new(1, -82, 0.5, 0); kbtn.AnchorPoint = Vector2.new(0, 0.5); kbtn.BackgroundColor3 = currentTheme.topbar; kbtn.Text = K.Value; kbtn.TextColor3 = currentTheme.primary; kbtn.TextSize = 12; kbtn.Font = Enum.Font.GothamBold; kbtn.ZIndex = 6; kbtn.Parent = f
            table.insert(Window._reg, {obj = kbtn, prop = "BackgroundColor3", key = "topbar"}); table.insert(Window._reg, {obj = kbtn, prop = "TextColor3", key = "primary"})
            local kbc = Instance.new("UICorner"); kbc.CornerRadius = UDim.new(0, 6); kbc.Parent = kbtn

            local listn = false
            kbtn.MouseButton1Click:Connect(function() listn = true; kbtn.Text = "..." end)
            UserInputService.InputBegan:Connect(function(inp)
                if listn and inp.KeyCode ~= Enum.KeyCode.Unknown then
                    K.Value = inp.KeyCode.Name; kbtn.Text = K.Value; listn = false
                    if c.Callback then c.Callback(K.Value) end
                elseif not listn and inp.KeyCode.Name == K.Value and c.Callback then
                    c.Callback(K.Value)
                end
            end)

            function K:SetValue(v) K.Value = v; kbtn.Text = v end
            AuraUI.Options[n] = K; return K
        end

        function Tab:AddParagraph(c)
            local lineCt = c.Content and (select(2, c.Content:gsub('\n', '\n')) + 1) or 1
            local h = 32 + (lineCt * 16)
            local f = baseObj(h)
            local t = addLbl(f, c.Title or "Info", 13, Enum.Font.GothamBold, currentTheme.primary, nil, 12, 8); t.Size = UDim2.new(1, -20, 0, 16)
            table.insert(Window._reg, {obj = t, prop = "TextColor3", key = "primary"})
            local m = addLbl(f, c.Content or "", 12, Enum.Font.Gotham, currentTheme.textDim, nil, 12, 26); m.Size = UDim2.new(1, -20, 0, h - 34); m.TextWrapped = true; m.TextYAlignment = Enum.TextYAlignment.Top
            table.insert(Window._reg, {obj = m, prop = "TextColor3", key = "textDim"})
        end

        if firstTab == nil then firstTab = Tab.Name end
        return Tab
    end

    function Window:SelectTab(name)
        for n, dat in pairs(Window.Tabs) do
            if n == name then
                tw(dat.Btn, {BackgroundColor3 = currentTheme.primary, TextColor3 = currentTheme.text}, 0.2); tw(dat.Str, {BackgroundTransparency = 0}, 0.2)
                dat.Frame.Visible = true; Window.CurrentTab = n
            else
                tw(dat.Btn, {BackgroundColor3 = currentTheme.element, TextColor3 = currentTheme.textDim}, 0.2); tw(dat.Str, {BackgroundTransparency = 1}, 0.2)
                dat.Frame.Visible = false
            end
        end
    end

    -- Automatically Build Settings Tab
    task.spawn(function()
        task.wait(0.1) -- Wait briefly for user to make their normal tabs first
        local sTab = Window:AddTab({Title = "⚙ Settings"})
        
        sTab:AddParagraph({Title = "Interface Control", Content = "Pick a visual theme."})
        local tNames = {}; for _, t in ipairs(Themes) do table.insert(tNames, t.name) end
        local tDrop = sTab:AddDropdown("ThemeSelector", {Title = "Current Theme", Values = tNames, Default = currentTheme.name, Callback = function(v) Window:SetTheme(v) end})
        ConfigSystem.Ignore["ThemeSelector"] = true

        sTab:AddParagraph({Title = "Configuration Management", Content = "Save and load your preferences."})
        sTab:AddInput("ConfigName", {Title = "Config Name", Placeholder = "your_config_name"})
        local cDrop = sTab:AddDropdown("ConfigList", {Title = "Saved Configs", Values = ConfigSystem:RefreshList()})
        ConfigSystem.Ignore["ConfigName"] = true; ConfigSystem.Ignore["ConfigList"] = true

        sTab:AddButton({Title = "Save Config", Description = "Writes all settings", Callback = function()
            local n = AuraUI.Options.ConfigName.Value
            if n == "" then return AuraUI:Notify({Title = "Error", Content = "Type a config name first.", Duration = 3}) end
            local ok, err = ConfigSystem:Save(n)
            if ok then AuraUI:Notify({Title = "Saved", Content = "Saved " .. n, Duration = 3}); cDrop:SetValues(ConfigSystem:RefreshList())
            else AuraUI:Notify({Title = "Error", Content = err, Duration = 3}) end
        end})

        sTab:AddButton({Title = "Load Config", Description = "Applies settings", Callback = function()
            local n = AuraUI.Options.ConfigList.Value
            if not n then return AuraUI:Notify({Title = "Error", Content = "Select a config.", Duration = 3}) end
            local ok, err = ConfigSystem:Load(n)
            if ok then AuraUI:Notify({Title = "Loaded", Content = "Loaded " .. n, Duration = 3})
            else AuraUI:Notify({Title = "Error", Content = err, Duration = 3}) end
        end})

        sTab:AddButton({Title = "Set as Autoload", Description = "Forces this config to load on startup", Callback = function()
            local n = AuraUI.Options.ConfigList.Value
            if not n then return end
            writefile(ConfigSystem.Folder .. "/settings/autoload.txt", n)
            AuraUI:Notify({Title = "Autoload Set", Content = n .. " will load next time.", Duration = 3})
        end})

        if firstTab then Window:SelectTab(firstTab) end
    end)
    
    -- Entrance Anim & Autoload Trigger
    playSound(Sounds.open, 0.5, 1); tw(mf, {Size = UDim2.fromScale(0.45, 0.65)}, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    task.delay(0.5, function() ConfigSystem:LoadAutoload() end)

    return Window
end

-- ── NOTIFICATION SYSTEM ───────────────────────────────────────────────────────
local notifCount = 0
function AuraUI:Notify(cfg)
    notifCount = notifCount + 1; local slot = notifCount; playSound(Sounds.whoosh, 0.4, 1.1)

    local ng = Instance.new("ScreenGui"); ng.Name = "AuraNotif"; ng.Parent = (gethui and gethui()) or CoreGui
    local f = Instance.new("Frame"); f.Size = UDim2.new(0, 270, 0, 70); f.Position = UDim2.new(1, 10, 1,
        -(80 + (slot - 1) * 80))
    f.BackgroundColor3 = currentTheme.topbar; f.BorderSizePixel = 0; f.Parent = ng
    local nc = Instance.new("UICorner"); nc.CornerRadius = UDim.new(0, 10); nc.Parent = f
    local ns = Instance.new("UIStroke"); ns.Color = currentTheme.primary; ns.Thickness = 1.5; ns.Parent = f

    local acl = Instance.new("Frame"); acl.Size = UDim2.new(0, 3, 0.7, 0); acl.Position = UDim2.new(0, 0, 0.15, 0)
    acl.BackgroundColor3 = currentTheme.primary; acl.BorderSizePixel = 0; acl.Parent = f
    local acc = Instance.new("UICorner"); acc.CornerRadius = UDim.new(0, 4); acc.Parent = acl

    local nt = Instance.new("TextLabel"); nt.Size = UDim2.new(1, -20, 0, 20); nt.Position = UDim2.new(0, 14, 0, 6)
    nt.BackgroundTransparency = 1; nt.Text = cfg.Title or "Notification"; nt.TextColor3 = currentTheme.text
    nt.TextSize = 14; nt.Font = Enum.Font.GothamBold; nt.TextXAlignment = Enum.TextXAlignment.Left; nt.Parent = f

    local nl = Instance.new("TextLabel"); nl.Size = UDim2.new(1, -20, 0, 30); nl.Position = UDim2.new(0, 14, 0, 28)
    nl.BackgroundTransparency = 1; nl.Text = cfg.Content or ""; nl.TextColor3 = currentTheme.textDim
    nl.TextSize = 12; nl.Font = Enum.Font.Gotham; nl.TextXAlignment = Enum.TextXAlignment.Left; nl.TextWrapped = true
    nl.TextYAlignment = Enum.TextYAlignment.Top; nl.Parent = f

    TweenService:Create(f, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -280, 1, -(80 + (slot - 1) * 80))}):Play()
    task.wait(cfg.Duration or 5)
    TweenService:Create(f, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 10, 1, -(80 + (slot - 1) * 80))}):Play()
    task.wait(0.35); ng:Destroy(); notifCount = math.max(0, notifCount - 1)
end

return AuraUI

