                TBg.Parent = Wrap 
                Reg(TBg, "BackgroundColor3", "InputBg") 
                Corner(TBg, 3) 
 
                local Fill = Instance.new("Frame") 
                Fill.Size = UDim2.new((Sld.Value - opts.Min) / (opts.Max - opts.Min), 0, 1, 0) 
                Fill.BackgroundColor3 = AuraUI.Theme.Primary 
                Fill.BorderSizePixel = 0 
                Fill.Parent = TBg 
                Reg(Fill, "BackgroundColor3", "Primary") 
