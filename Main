    local function toggleMin()
        if isMin then
            isMin = false; Window.isMinimized = false; playSound(Sounds.whoosh, 0.4, 1.15)
            tw(mini, {Size = UDim2.new(0, 0, 0, 0)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In)
